# Data backend: "local" (default) uses the JSON seed + data/runtime files.
# Set to "supabase" once your Supabase project is live and env vars below are filled in.
DATA_BACKEND=local

# Supabase (only needed when DATA_BACKEND=supabase)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (only needed to actually send confirmation emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@discernly.io

# Amazon Associates tag. Defaults to "discernly-20" in code (see
# src/lib/affiliate.ts) even if this is left blank — only set this if the
# tag ever needs to change without a code deploy.
AMAZON_ASSOCIATE_TAG=
